# ===========================================================================
# ATMS — production environment template (split-subdomain deployment)
# --------------------------------------------------------------------------
# Copy to `.env` on the VPS and fill in every value. This file is read by
# Docker Compose (`compose.yaml` + `compose.production.yaml`) via the
# `--env-file .env` flag in deploy.sh. NEVER commit a filled-in copy.
#
#   SPA host:  https://atms.inova.krd
#   API host:  https://atmsapi.inova.krd
# ===========================================================================

# ---- Application -----------------------------------------------------------
APP_ENV=production
APP_DEBUG=false
# Generate on the VPS: docker compose run --rm api php artisan key:generate
APP_KEY=
APP_URL=https://atmsapi.inova.krd

# Public-facing hosts (consumed by Caddyfile defaults + deploy checks).
APP_HOST=atms.inova.krd
API_HOST=atmsapi.inova.krd

# Port the Docker `nginx` container binds on the host. Caddy proxies to it.
# Keep this behind the firewall — Caddy is the only public listener (443).
WEB_PORT=8080
BACKEND_PORT=8080

# ---- Sanctum SPA cookie auth (CROSS-SUBDOMAIN) -----------------------------
# Both subdomains share the registrable domain `inova.krd`, so cookies CAN be
# shared across them. Three values must be set together or login will silently
# fail with 401 / 419:
#
#   SESSION_DOMAIN           = .inova.krd   (cookie scope, covers both subs)
#   SANCTUM_STATEFUL_DOMAINS = atms.inova.krd  (the SPA origin only)
#   CORS_ALLOWED_ORIGINS     = https://atms.inova.krd  (exact origin, no wildcard)
SESSION_DOMAIN=.inova.krd
SANCTUM_STATEFUL_DOMAINS=atms.inova.krd
CORS_ALLOWED_ORIGINS=https://atms.inova.krd
CORS_SUPPORTS_CREDENTIALS=true

# ---- Database --------------------------------------------------------------
DB_DATABASE=atms
DB_USERNAME=atms
# Min 32 random chars. Generate: openssl rand -base64 48
DB_PASSWORD=

# ---- Timezone --------------------------------------------------------------
ATMS_COMPANY_TIMEZONE=Africa/Tripoli

# ---- Attachments -----------------------------------------------------------
ATMS_ATTACHMENT_DISK=attachments

# ---- Account email transport (activation + password reset) -----------------
# `fake` for demo; `power_automate` for client production.
ACCOUNT_EMAIL_TRANSPORT=fake
POWER_AUTOMATE_URL=
POWER_AUTOMATE_TENANT_ID=
POWER_AUTOMATE_CLIENT_ID=
POWER_AUTOMATE_CLIENT_SECRET=
POWER_AUTOMATE_MAILBOX=

# ---- ERP integration (Business Central) ------------------------------------
# Parts sync from ERP → SM. Leave blank for the demo if ERP creds aren't ready;
# the sync job will fail open and the rest of the app works.
LDC_ERP_TENANT_ID=
LDC_ERP_CLIENT_ID=
LDC_ERP_CLIENT_SECRET=
LDC_ERP_ENVIRONMENT=Production
LDC_ERP_COMPANY=
# API page name — still TBD from the ERP team per docs/03-backend/ERP_SYNC.md.
LDC_ERP_PARTS_API=

# ---- Misc ------------------------------------------------------------------
EMPLOYEE_VISIBLE_EMP_IDS=
