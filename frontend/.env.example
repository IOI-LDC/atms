# ===========================================================================
# ATMS frontend — Vite environment variables
# --------------------------------------------------------------------------
# Copy to `.env.production` for a production build, or set per-environment.
# Vite only exposes variables prefixed with VITE_ to the client bundle.
# ===========================================================================

# API origin. Controls where the SPA sends /api/* and /sanctum/csrf-cookie.
#
#   - Same-origin (dev, or single-domain prod): leave EMPTY so the SPA uses
#     relative paths and the Vite dev-server proxy / Caddy passthrough handles
#     routing. Example: VITE_API_ORIGIN=
#
#   - Cross-origin (split subdomain prod: SPA on atms.inova.krd, API on
#     atmpapi.inova.krd): set to the full HTTPS origin of the backend.
#     Example: VITE_API_ORIGIN=https://atmpapi.inova.krd
#
# IMPORTANT: when set, the backend MUST allow this origin via
# CORS_ALLOWED_ORIGINS and treat it as stateful via SANCTUM_STATEFUL_DOMAINS,
# otherwise cookie auth fails with CORS / 401 errors.
VITE_API_ORIGIN=
