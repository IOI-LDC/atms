{
  "$schema": "https://app.kilo.ai/config.json",
  "mcp": {
    "shadcn": {
      "type": "local",
      "command": ["npx", "-y", "shadcn@canary", "registry:mcp"],
      "environment": {
        "REGISTRY_URL": "https://tweakcn.com/r/themes/registry.json"
      }
    },
    "laravel-boost": {
      "type": "local",
      "command": ["bash", "scripts/boost-mcp.sh"]
    }
  }
}
